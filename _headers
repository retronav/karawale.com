/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://umami.karawale.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://blog.karawale.com; object-src 'none'; connect-src 'self' https://umami.karawale.com; frame-src youtube.com www.youtube.com
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/_app/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.avif
  Cache-Control: public, max-age=31536000, immutable

# Static URLs but with changing content

/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate

/robots.txt
  Cache-Control: public, max-age=0, must-revalidate

/resume.pdf
  Cache-Control: public, max-age=0, must-revalidate

/logo.png
  Cache-Control: public, max-age=0, must-revalidate

/pubkey.asc
  Cache-Control: public, max-age=0, must-revalidate

/rss-style.xsl
  Cache-Control: public, max-age=0, must-revalidate
